# Database
DATABASE_URL="postgresql://user:password@localhost:5432/clearpath_dx?schema=public"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3001"

# Resend (email magic links)
AUTH_RESEND_KEY="re_xxxxxxxxxxxx"
RESEND_FROM_EMAIL="noreply@clearpathdx.com"

# Twilio (SMS OTP) — optional for dev, console.log fallback
TWILIO_ACCOUNT_SID="ACxxxxxxxxxx"
TWILIO_AUTH_TOKEN="xxxxxxxxxx"
TWILIO_PHONE_NUMBER="+1xxxxxxxxxx"

# App URLs
NEXT_PUBLIC_WEB_URL="http://localhost:3000"
NEXT_PUBLIC_PLATFORM_URL="http://localhost:3001"
